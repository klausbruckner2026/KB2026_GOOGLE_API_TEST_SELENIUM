{
  "name": "selenium-test-framework",
  "version": "1.0.0",
  "description": "Bosch-compliant Selenium test framework for Google Search validation",
  "main": "index.js",
  "scripts": {
    "test": "mocha --timeout 30000 --reporter mochawesome",
    "test:chrome": "mocha --timeout 30000 --reporter mochawesome --browser=chrome",
    "test:headless": "mocha --timeout 30000 --reporter mochawesome --headless",
    "report": "open mochawesome-report/mochawesome.html",
    "clean": "rm -rf mochawesome-report/",
    "lint": "eslint tests/"
  },
  "keywords": ["selenium", "testing", "automation", "bosch"],
  "author": "Bosch [Department Name]",
  "license": "Proprietary",
  "devDependencies": {
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "chromedriver": "^119.0.0",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "selenium-webdriver": "^4.15.0"
  }
}
